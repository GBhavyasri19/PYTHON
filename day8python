displaying radius for circle
class circle:
    def __init__(self):
        x=int(input("Enter Radius:"))
        self.r=x
    def display(self):
        print("Area is: ",3.14*self.r**2)

a=int(input("Enter num of circle: "))
l=[]
for i in range(a):
    c=circle()
    l.append(c)
    c.display()
    print("_____________________________________")
